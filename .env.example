# Copy to .env and adjust only if your file locations differ.

# --- Core backend ---
LOG_LEVEL=INFO
TERRAWATCH_DATA_DIR=./data
USGS_CACHE_CSV=./data/usgs_catalog.csv
AFTERSHOCK_MODEL_PATH=./aftershock_transformer_scripted.pt
USGS_POLL_SECONDS=180
LIVE_CATALOG_HOURS=48

# --- Damage assessment models ---
TERRAWATCH_MODEL_ROOT=./terrawatch/models
YOLO_RUNS_DIR=./runs/detect
YOLO_WEIGHTS_PATH=
YOLO_CONF_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45
YOLO_IMAGE_SIZE=640

# --- ESRGAN enhancement model ---
# Path to the Real-ESRGAN weights. If you don't have the file locally you can
# grab it with `bash scripts/fetch_weights.sh` (or download manually).
ESRGAN_WEIGHTS_PATH=./terrawatch/RealESRGAN_x4plus.pth
ESRGAN_SCALE=4
ESRGAN_OUTSCALE=2.0

# Set to 1 only if torch import crashes on your machine.
DISABLE_TORCH=0

# Frontend: set 1 to enable ESRGAN refinement second-pass
VITE_ENABLE_REFINEMENT=0
